{
  "expo": {
    "name": "Borteh Sprays",
    "slug": "borteh-sprays",
    "scheme": "borteh",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#FAF8F5",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bortehsprays.app"
    },
    "android": {
      "package": "com.bortehsprays.app",
      "adaptiveIcon": {
        "backgroundColor": "#FAF8F5"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
